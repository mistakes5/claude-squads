{
  "name": "squads",
  "version": "0.1.0",
  "description": "Social lobbies for Claude Code — squad up with friends",
  "type": "module",
  "bin": {
    "squads": "./dist/squads.js"
  },
  "scripts": {
    "build": "tsup && tsup --config tsup.overlay.ts && cp src/overlay/overlay.html dist/overlay/",
    "build:overlay": "tsup --config tsup.overlay.ts && cp src/overlay/overlay.html dist/overlay/",
    "overlay": "pnpm build:overlay && npx electron dist/overlay/main.cjs",
    "dev:tui": "tsx src/tui/cli.ts",
    "dev:mcp": "tsx src/mcp/server.ts",
    "setup": "tsx scripts/setup.ts"
  },
  "keywords": [
    "claude-code",
    "social",
    "squads",
    "mcp"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@supabase/supabase-js": "^2.99.1",
    "ink": "^6.8.0",
    "ink-text-input": "^6.0.0",
    "open": "^11.0.0",
    "react": "^19.2.4"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "electron": "^41.0.2",
    "electron-builder": "^26.8.1",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
