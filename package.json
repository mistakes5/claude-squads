{
  "name": "squade-code",
  "version": "0.1.0",
  "description": "Squade Code — social lobbies for Claude Code",
  "type": "module",
  "bin": {
    "squade": "./dist/squads.js"
  },
  "scripts": {
    "build": "tsup && tsup --config tsup.overlay.ts && cp src/overlay/overlay.html dist/overlay/",
    "build:overlay": "tsup --config tsup.overlay.ts && cp src/overlay/overlay.html dist/overlay/",
    "overlay": "pnpm build && npx electron dist/overlay/main.cjs",
    "relaunch": "pkill -f 'electron dist/overlay' 2>/dev/null; sleep 0.5; pnpm overlay",
    "package": "pnpm build && electron-builder --mac --dir",
    "dev:tui": "tsx src/tui/cli.ts",
    "dev:mcp": "tsx src/mcp/server.ts",
    "server": "tsx server/index.ts",
    "server:dev": "tsx watch server/index.ts",
    "setup": "tsx scripts/setup.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "build": {
    "appId": "com.squadecode.app",
    "productName": "Squade Code",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "assets/icon.icns",
      "target": [
        "dir"
      ]
    },
    "extraMetadata": {
      "main": "dist/overlay/main.cjs"
    }
  },
  "keywords": [
    "claude-code",
    "social",
    "squade",
    "mcp"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@supabase/supabase-js": "^2.99.1",
    "cors": "^2.8.6",
    "dotenv": "^16.4.7",
    "express": "^5.2.1",
    "ink": "^6.8.0",
    "ink-text-input": "^6.0.0",
    "jsonwebtoken": "^9.0.3",
    "open": "^11.0.0",
    "pg": "^8.20.0",
    "react": "^19.2.4",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.5.0",
    "@types/pg": "^8.18.0",
    "@types/react": "^19.2.14",
    "electron": "^41.0.2",
    "electron-builder": "^26.8.1",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
